# Mahjong+× — build-time configuration sourced by scripts/run-ios.sh and
# scripts/release-testflight.sh before they call xcodegen. Override any of
# these by exporting them in your shell, or by editing this file (committed).
#
# DEVELOPMENT_TEAM is empty by default — fill it with your 10-char Team ID
# (App Store Connect → Membership) before going to TestFlight.
DEVELOPMENT_TEAM=
BUNDLE_ID=com.mahjongplusx.app
MARKETING_VERSION=0.1.0
BUILD_NUMBER=1
